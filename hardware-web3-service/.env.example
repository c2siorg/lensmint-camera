# Server
PORT=5000
NODE_ENV=production

# File paths
CAPTURES_PATH=/home/pi/lensmint/captures
DATABASE_PATH=/home/pi/lensmint/data/lensmint.db

# Blockchain
PRIVATE_KEY=device_wallet_private_key_here
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Smart contracts
DEVICE_REGISTRY_ADDRESS=DeviceRegistryContractAddress
LENMINT_ERC1155_ADDRESS=LensMintERC1155ContractAddress
VERIFIER_CONTRACT_ADDRESS=VerifierContractAddress

# Owner wallet
OWNER_WALLET_ADDRESS=OwnerWalletAddress

# Claim server
CLAIM_SERVER_URL=https://lensmint.onrender.com
CLAIM_CLIENT_TIMEOUT=30000

# Filecoin
FILECOIN_NETWORK=calibration
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
DEVICE_PRIVATE_KEY=filecoin_wallet_private_key_here

# ZK Proof
WEB_PROVER_API_CLIENT_ID=vlayer_client_id_here
WEB_PROVER_API_SECRET=vlayer_api_secret_here
ZK_PROVER_API_URL=https://prove.vlayer.xyz

# Privy
PRIVY_APP_ID=privy_app_id_here
PRIVY_APP_SECRET=privy_app_secret_here

# Optional balances
MIN_ETH_BALANCE=0.01
MIN_USDFC_BALANCE=0.1